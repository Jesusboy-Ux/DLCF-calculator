# Copy this file to .env and fill in real values before running anything.

# Local Postgres example. Swap for your provider's connection string
# (Railway, Render, Supabase, Neon all give you one of these).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cgpa_dev"

# Any long random string — used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# How long an access token stays valid
JWT_EXPIRES_IN="7d"

PORT=4000
